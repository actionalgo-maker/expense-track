<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ImageButton
                android:id="@+id/prevMonthButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/card_bg"
                android:backgroundTint="@color/card2"
                android:src="@drawable/ic_chevron_left"
                android:scaleType="center"
                android:contentDescription="Previous month"/>

            <TextView
                android:id="@+id/reportMonthLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="July 2026"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <ImageButton
                android:id="@+id/nextMonthButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/card_bg"
                android:backgroundTint="@color/card2"
                android:src="@drawable/ic_chevron_right"
                android:scaleType="center"
                android:contentDescription="Next month"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total spent"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/reportTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="By category"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="10dp"/>

            <com.yonko.expensetracker.ui.reports.BarChartView
                android:id="@+id/categoryChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily spend"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="10dp"/>

            <com.yonko.expensetracker.ui.reports.DailyBarChartView
                android:id="@+id/dailyChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="90dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/exportButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:backgroundTint="@color/card2"
                android:text="Export CSV (backup)"
                android:textColor="@color/text_primary"
                android:textAllCaps="false"/>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
